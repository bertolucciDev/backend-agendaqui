generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String  @id @default(uuid())
  name             String
  email            String  @unique
  phone            String? @unique
  passwordHash     String
  isVerified       Boolean @default(false)
  profileCompleted Boolean @default(false)

  role PlatformRole @default(CLIENT)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  subscriptions  Subscription[]
  memberships    Membership[]
  bookings       Booking[]
  discountUsages DiscountUsage[]
  verifications  Verification[]
}

enum PlatformRole {
  CLIENT
  OWNER
  STAFF
  ADMIN
}

model Business {
  id           String          @id @default(uuid())
  name         String
  document     String          @unique
  documentType LegalEntityType
  isActive     Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations   Location[]
  memberships Membership[]
}

enum LegalEntityType {
  CPF
  CNPJ
}

model Membership {
  id         String      @id @default(uuid())
  userId     String
  businessId String
  role       CompanyRole

  user     User     @relation(fields: [userId], references: [id])
  business Business @relation(fields: [businessId], references: [id])

  @@unique([userId, businessId])
}

enum CompanyRole {
  OWNER
  STAFF
}

model Location {
  id          String  @id @default(uuid())
  name        String
  description String?
  isActive    Boolean @default(true)

  latitude  Float
  longitude Float
  address   String

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services  Service[]
  discounts Discount[]
  bookings  Booking[]

  @@index([businessId])
}

model Service {
  id              String  @id @default(uuid())
  name            String
  description     String?
  basePrice       Int // cents
  durationMinutes Int
  isActive        Boolean @default(true)

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  discounts Discount[]
  bookings  Booking[]

  @@index([locationId])
}

model Discount {
  id         String  @id @default(uuid())
  locationId String
  serviceId  String?

  percentage  Int?
  fixedAmount Int?
  maxUses     Int?
  isExclusive Boolean @default(true)
  isActive    Boolean @default(true)

  startAt DateTime
  endAt   DateTime?

  location Location @relation(fields: [locationId], references: [id])
  service  Service? @relation(fields: [serviceId], references: [id])

  bookings Booking[]
}

model Booking {
  id         String  @id @default(uuid())
  userId     String
  locationId String
  serviceId  String
  discountId String?

  basePrice      Int
  discountAmount Int?
  finalPrice     Int

  status      BookingStatus
  scheduledAt DateTime

  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  location Location  @relation(fields: [locationId], references: [id])
  service  Service   @relation(fields: [serviceId], references: [id])
  discount Discount? @relation(fields: [discountId], references: [id])

  discountUsage DiscountUsage?

  @@index([locationId, scheduledAt])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}

model DiscountUsage {
  id             String @id @default(uuid())
  userId         String
  subscriptionId String
  bookingId      String

  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  booking      Booking      @relation(fields: [bookingId], references: [id])

  @@unique([bookingId])
}

model Plan {
  id          String  @id @default(uuid())
  name        String
  description String?

  discountLimit     Int?
  hasUnlimitedUsage Boolean @default(false)

  trialDays Int? @default(0)

  isActive Boolean @default(true)

  prices        Price[]
  subscriptions Subscription[]
}

model Price {
  id            String          @id @default(uuid())
  planId        String
  amount        Int // cents
  currency      String          @default("BRL")
  interval      BillingInterval
  intervalCount Int             @default(1)
  isActive      Boolean         @default(true)

  plan          Plan           @relation(fields: [planId], references: [id])
  subscriptions Subscription[]
}

enum BillingInterval {
  MONTH
  YEAR
}

model Subscription {
  id         String             @id @default(uuid())
  userId     String
  planId     String
  priceId    String
  externalId String?
  status     SubscriptionStatus

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEnd           DateTime?
  canceledAt         DateTime?
  endedAt            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  plan  Plan  @relation(fields: [planId], references: [id])
  price Price @relation(fields: [priceId], references: [id])

  discountUsages DiscountUsage[]

  @@index([userId])
  @@index([userId, status])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

model Verification {
  id        String           @id @default(uuid())
  userId    String
  token     String           @unique
  code      String
  type      VerificationType
  expiresAt DateTime
  isUsed    Boolean          @default(false)
  createdAt DateTime         @default(now())
  usedAt    DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([code])
}

enum VerificationType {
  PASSWORD_RESET @map("password_reset")
  VERIFY_EMAIL   @map("verify_email")
}
