generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER        // Usuário comum do sistema
  ADMIN       // Administrador com permissões elevadas
}

enum BookingStatus {
  PENDING     // Agendamento aguardando confirmação
  CONFIRMED   // Agendamento confirmado
  CANCELED    // Agendamento cancelado
  COMPLETED   // Agendamento concluído
}

model User {
  id         String   @id @default(uuid())      // ID único gerado automaticamente (UUID)
  name       String                              // Nome do usuário
  email      String   @unique                    // Email único usado para login
  password   String                              // Senha criptografada
  role       Role     @default(USER)             // Tipo do usuário (USER por padrão)
  isVerified Boolean  @default(false)            // Indica se o email foi verificado
  createdAt  DateTime @default(now())            // Data de criação automática
  updatedAt  DateTime @updatedAt                 // Atualiza automaticamente ao modificar
}

model Subscription {
  id         String   @id @default(uuid())       // ID único da assinatura
  planType   String                              // Tipo do plano (ex: BASIC, PREMIUM)
  price      Decimal  @db.Decimal(10,2)          // Valor monetário com 2 casas decimais
  startDate  DateTime @default(now())            // Data de início da assinatura
  endDate    DateTime?                           // Data de término (opcional)
  active     Boolean  @default(true)             // Indica se a assinatura está ativa
  createdAt  DateTime @default(now())            // Data de criação
  updatedAt  DateTime @updatedAt                 // Data de atualização automática
}

model Establishment {
  id           String      @id @default(uuid())  // ID único do estabelecimento
  name         String                            // Nome do estabelecimento
  description  String?                           // Descrição opcional
  phone        String?                           // Telefone opcional
  address      String                            // Endereço completo
  latitude     Float                             // Latitude para localização no mapa
  longitude    Float                             // Longitude para localização no mapa

  employees    Employee[]                        // Lista de funcionários (relação 1:N)
  services     Service[]                         // Lista de serviços oferecidos (1:N)
  bookings     Booking[]                         // Lista de agendamentos (1:N)

  createdAt    DateTime    @default(now())       // Data de criação
  updatedAt    DateTime    @updatedAt            // Data de atualização automática
}

model Employee {
  id               String        @id @default(uuid())  // ID único do funcionário
  name             String                              // Nome do funcionário
  specialty        String?                             // Especialidade (opcional)

  establishmentId  String                              // Chave estrangeira do estabelecimento
  establishment    Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade) // Relação com Establishment (se deletar o estabelecimento, deleta funcionários)

  bookings         Booking[]                           // Agendamentos vinculados ao funcionário
}

model Service {
  id               String        @id @default(uuid())  // ID único do serviço
  name             String                              // Nome do serviço
  price            Decimal       @db.Decimal(10,2)     // Preço do serviço
  durationMinutes  Int                                 // Duração do serviço em minutos

  establishmentId  String                              // Chave estrangeira do estabelecimento
  establishment    Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade) // Relação com Establishment

  bookings         Booking[]                           // Agendamentos que incluem esse serviço
}

model Booking {
  id               String        @id @default(uuid())  // ID único do agendamento
  date             DateTime                            // Data do agendamento
  time             String                              // Horário do agendamento (ex: "14:30")
  peopleCount      Int                                 // Quantidade de pessoas
  status           BookingStatus @default(PENDING)     // Status atual do agendamento
  totalAmount      Decimal?      @db.Decimal(10,2)     // Valor total calculado (opcional)

  establishmentId  String                              // Chave estrangeira do estabelecimento
  establishment    Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade) // Relação com Establishment

  employeeId       String?                             // Chave estrangeira opcional do funcionário
  employee         Employee?     @relation(fields: [employeeId], references: [id]) // Relação opcional com funcionário

  services         Service[]                           // Relação muitos-para-muitos com serviços

  createdAt        DateTime      @default(now())       // Data de criação
  updatedAt        DateTime      @updatedAt            // Atualização automática
}
